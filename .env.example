# =============================================================================
# StudyFlow – Optional environment variables (app works without these)
# =============================================================================
# Copy to .env and fill in only what you use. Vite exposes VITE_* to the client.
# =============================================================================

# --- AI (optional) ---
# Use local Ollama (localhost:11434). Run: ollama pull llama3.2
# Start with CORS for browser: OLLAMA_ORIGINS=* ollama serve
VITE_OLLAMA_ENABLED=true
# VITE_OLLAMA_MODEL=llama3.2   # Optional: prefer this model (falls back to llama3, mistral, etc.)

# Cloud AI – only if you add a small proxy or use client-side with caution
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Media (optional) ---
# ELEVENLABS_API_KEY=     # Premium TTS
# Image search (Studio: "Add image" → Search Web). Without these, only upload/URL works.
# VITE_GOOGLE_CSE_KEY=      # Google Custom Search API key (optional)
# VITE_GOOGLE_CSE_CX=       # Google Programmable Search Engine ID (optional)
# VITE_BING_API_KEY=        # Bing Image Search (Azure). Free tier: 1000 searches/month
# VITE_UNSPLASH_ACCESS_KEY= # unsplash.com/developers – 50 req/hour
# VITE_PEXELS_API_KEY=      # pexels.com/api – 200 req/hour (fallback)
# GOOGLE_VISION_API_KEY=  # Better handwriting OCR (else Tesseract.js in browser)

# --- Accounts & cloud sync (optional) ---
# Supabase: sign up / sign in and save flashcards to the cloud. See README.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Ollama server (host only; CORS) ---
# OLLAMA_ORIGINS=* ollama serve
